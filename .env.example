# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings
DATABASE_URL="postgres://USER:PASSWORD@host:5432/"

# URL pública de produção (usada em links de WhatsApp, metadados e sitemap)
NEXT_PUBLIC_URL="https://seu-dominio.com.br"

# Autenticação (sessão via JWT em cookie httpOnly) — gere um valor com pelo menos 32 caracteres
JWT_SECRET=""

# Evolution API (integração de WhatsApp)
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE_NAME=""

# FTP (envio/recebimento de arquivos de laudos)
FTP_HOST=""
FTP_PORT="21"
FTP_USER=""
FTP_PASSWORD=""
FTP_SECURE="false"
